{
  "schema_version": "1.0",
  "knowledge_base": {
    "name": "BrowseForge Chromium Runtime Knowledge Base",
    "purpose": "Source-grounded knowledge base for the Chromium-family BrowseForge runtime, including contracts, architecture, wrapper scope, detector evidence, and graph framework.",
    "owner": "nczz",
    "visibility": "open-source-ready"
  },
  "sources": [
    {
      "source_id": "runtime-repo-contracts",
      "kind": "runtime_contract",
      "repo": "nczz/browseforge-runtime-chromium",
      "ref": "main",
      "path_globs": [
        "contracts/**/*.json"
      ],
      "exclude": [],
      "sensitive": false,
      "index_targets": [
        "kb",
        "kg"
      ]
    },
    {
      "source_id": "runtime-repo-docs",
      "kind": "docs",
      "repo": "nczz/browseforge-runtime-chromium",
      "ref": "main",
      "path_globs": [
        "README.md",
        "SECURITY.md",
        "docs/**/*.md"
      ],
      "exclude": [],
      "sensitive": false,
      "index_targets": [
        "kb"
      ]
    },
    {
      "source_id": "runtime-repo-detectors",
      "kind": "detector_evidence_contract",
      "repo": "nczz/browseforge-runtime-chromium",
      "ref": "main",
      "path_globs": [
        "detectors/**/*.json"
      ],
      "exclude": [
        "detectors/raw/**"
      ],
      "sensitive": false,
      "index_targets": [
        "kb",
        "kg"
      ]
    },
    {
      "source_id": "runtime-repo-graph",
      "kind": "knowledge_graph_framework",
      "repo": "nczz/browseforge-runtime-chromium",
      "ref": "main",
      "path_globs": [
        "graph/**/*.md",
        "graph/**/*.cypher"
      ],
      "exclude": [
        "graph/exports/**"
      ],
      "sensitive": false,
      "index_targets": [
        "kb",
        "kg"
      ]
    },
    {
      "source_id": "browseforge-consumer-contract",
      "kind": "browseforge_contract",
      "repo": "nczz/BrowseForge",
      "ref": "v2.0.0",
      "path_globs": [
        "internal/runtime/runtime.go",
        "internal/config/config.go",
        "internal/profile/store.go",
        "internal/browser/manager.go",
        "internal/browser/launch_chromium.go",
        "internal/browser/launch_helpers.go",
        "internal/browser/download.go",
        "internal/api/router.go",
        "internal/mcp/server.go",
        "internal/workflow/engine.go",
        "docs/dual-browser-architecture.md",
        "docs/anti-detection.md",
        "docs/fingerprint-detection-report.md",
        "docs/platform-support.md"
      ],
      "exclude": [],
      "sensitive": false,
      "index_targets": [
        "cross_repo_kg"
      ]
    },
    {
      "source_id": "cloakbrowser-reference",
      "kind": "chromium_reference_runtime",
      "repo": "browser-source-intel/CloakBrowser-v146.0.7680.177.4",
      "ref": "local-index",
      "path_globs": [
        "README.md",
        "browser/**/*.py",
        "browser/**/*.js",
        "docker/**/*.Dockerfile",
        "docs/**/*.md"
      ],
      "exclude": [
        "out/**",
        "build/**",
        "dist/**",
        "node_modules/**"
      ],
      "sensitive": false,
      "index_targets": [
        "reference_kb",
        "reference_kg",
        "cross_repo_kg"
      ]
    },
    {
      "source_id": "camoufox-reference",
      "kind": "firefox_reference_runtime",
      "repo": "browser-source-intel/Camoufox-v135.0.1-beta.24",
      "ref": "local-index",
      "path_globs": [
        "README.md",
        "docs/**/*.md",
        "pythonlib/**/*.py",
        "camoufox/**/*.py",
        "scripts/**/*.py"
      ],
      "exclude": [
        "obj*/**",
        "build/**",
        "dist/**",
        "node_modules/**"
      ],
      "sensitive": false,
      "index_targets": [
        "reference_kb",
        "reference_kg"
      ]
    },
    {
      "source_id": "chromium-upstream",
      "kind": "upstream_browser_source",
      "repo": "chromium/chromium",
      "ref": "refs/tags/150.0.7871.101",
      "path_globs": [
        "chrome/**",
        "content/**",
        "third_party/blink/**",
        "gpu/**",
        "media/**",
        "net/**",
        "services/network/**"
      ],
      "exclude": [
        "out/**",
        "build/**"
      ],
      "sensitive": false,
      "index_targets": [
        "future_kb",
        "future_kg"
      ],
      "status": "selected_not_indexed",
      "base_commit": "51b83660c3609f271ccbbd65785bf7e50a21312d"
    }
  ],
  "excluded_patterns": [
    "browser/src/**",
    "browser/out/**",
    "build/out/**",
    "dist/**",
    "artifacts/**",
    "profiles/**",
    "data/**",
    "logs/**",
    "backups/**",
    "detectors/raw/**",
    "**/*.zip",
    "**/*.tar.gz",
    "**/*.tgz",
    "**/*.dmg",
    "**/*.exe",
    "**/*.app"
  ],
  "generated_outputs": {
    "knowledge_export": "release artifact: knowledge-export.jsonl",
    "graph_export": "release artifact: graph.db.zst",
    "detector_summary": "release artifact: detector-summary.json"
  }
}
