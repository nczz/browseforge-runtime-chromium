{
  "$schema": "./runtime-manifest.schema.json",
  "id": "browseforge-chromium",
  "name": "BrowseForge Chromium Runtime",
  "family": "chromium",
  "version": "v0.1.0-alpha.0",
  "status": "planning",
  "browseforge": {
    "min_version": "v2.0.0",
    "runtime_id": "browseforge-chromium",
    "profile_field": "runtime_id"
  },
  "binary": {
    "linux-x64": {
      "relative_path": "chrome",
      "packaged": false
    },
    "macos-arm64": {
      "relative_path": "Chromium.app/Contents/MacOS/Chromium",
      "packaged": false
    },
    "macos-x64": {
      "relative_path": "Chromium.app/Contents/MacOS/Chromium",
      "packaged": false
    },
    "windows-x64": {
      "relative_path": "chrome.exe",
      "packaged": false
    }
  },
  "capabilities": {
    "persistent_context": true,
    "playwright_bind": true,
    "agent_web_sessions": true,
    "seed_fingerprint": true,
    "structured_config": true,
    "native_proxy": true,
    "webrtc_masking": true,
    "requires_external_binary": true
  },
  "profile": {
    "user_data_dir_policy": "one persistent user data directory per BrowseForge profile",
    "lock_policy": "runtime must fail clearly or repair transient locks without corrupting profile data",
    "migration_policy": "same-family Chromium profile migration may be supported only after explicit evidence"
  },
  "fingerprint": {
    "seed_input": "uint32",
    "surfaces": [
      "user_agent",
      "client_hints",
      "timezone",
      "locale",
      "screen",
      "hardware",
      "canvas",
      "webgl",
      "audio",
      "fonts",
      "permissions",
      "webrtc",
      "proxy_ip_coherence",
      "storage_quota",
      "automation_signals"
    ]
  },
  "artifacts": {
    "release_prefix": "browseforge-runtime-chromium",
    "checksums": "checksums.txt",
    "knowledge_export": "knowledge-export.jsonl",
    "graph_export": "graph.db.zst",
    "detector_summary": "detector-summary.json"
  }
}
